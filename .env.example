# Besu private chain. For robustness, open one IAP tunnel per validator on
# distinct local ports and list them all (comma-separated) — each oracle agent
# fails over across them if one validator/tunnel goes offline. RPC_URL (single)
# is still honored as a fallback if RPC_URLS is unset.
RPC_URLS=http://127.0.0.1:8545,http://127.0.0.1:8546,http://127.0.0.1:8547
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=20260416

# Funded genesis account private key (0x-prefixed). FILL THIS IN — leave blank in git.
DEPLOYER_PRIVATE_KEY=

# Deployed contract address (from Deploy.s.sol output)
CONTRACT_ADDRESS=

# TEE service (reach via IAP SSH port-forward to tee-node:8000).
# Use 127.0.0.1, NOT localhost (localhost may resolve to IPv6 ::1 and miss the IPv4 forward).
TEE_URL=http://127.0.0.1:8000
# TEE signing address (printed by tee_service.py on startup; also used by Deploy.s.sol)
TEE_ADDRESS=

# Oracle DON (m-of-n). Register these addresses at deploy; run one agent per key.
ORACLE_ADDRESSES=0xOracle1,0xOracle2,0xOracle3,0xOracle4
THRESHOLD=3
ORACLE_FUND_ETHER=1
# Per-agent (set differently in each agent's shell/instance):
ORACLE_ID=1
ORACLE_KEY=0x<this oracle's private key>

# Decryption DON nodes (one URL per kfrag). Ports must match run_decryption_nodes.py's
# BASE_PORT (use 5005+ on macOS — AirPlay occupies 5000).
DECRYPTION_NODE_URLS=http://127.0.0.1:5005,http://127.0.0.1:5006,http://127.0.0.1:5007
