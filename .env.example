# ── Besu private chain ──────────────────────────────────────────────────────
# For robustness, open one IAP tunnel per validator on distinct local ports and
# list them all (comma-separated) — each oracle agent fails over across them if a
# validator/tunnel goes offline. RPC_URL (single) is a fallback if RPC_URLS is unset.
RPC_URLS=http://127.0.0.1:8545,http://127.0.0.1:8546,http://127.0.0.1:8547
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=20260416

# Funded genesis account private key (0x-prefixed). FILL THIS IN — never commit a real value.
DEPLOYER_PRIVATE_KEY=

# Deployed contract address ('make bootstrap' writes this after it deploys).
CONTRACT_ADDRESS=

# ── TEE ─────────────────────────────────────────────────────────────────────
# Reach the TEE via the IAP SSH port-forward to tee-node:8000. Use 127.0.0.1, NOT
# localhost (localhost may resolve to IPv6 ::1 and miss the IPv4 forward).
TEE_URL=http://127.0.0.1:8000
# TEE signing address (printed by tee_service.py on startup; also used at deploy).
TEE_ADDRESS=

# ── Oracle DON (m-of-n attestation) ─────────────────────────────────────────
ORACLE_ADDRESSES=0xOracle1,0xOracle2,0xOracle3,0xOracle4
THRESHOLD=3
ORACLE_FUND_ETHER=1
# All oracle private keys, comma-separated, PARALLEL to ORACLE_ADDRESSES. This
# replaces the old per-agent ORACLE_ID/ORACLE_KEY lines — run_oracle_agents.py
# enumerates ORACLE_KEYS (ORACLE_ID = position, starting at 1). Delete any leftover
# ORACLE_ID=/ORACLE_KEY= lines from an older .env.
ORACLE_KEYS=0xkey1,0xkey2,0xkey3,0xkey4

# ── Decryption DON (umbral threshold re-encryption) ─────────────────────────
# keygen params ('make bootstrap'): shares = number of decryption nodes,
# threshold = re-encryption quorum m (NOT the oracle THRESHOLD above).
UMBRAL_SHARES=3
UMBRAL_THRESHOLD=2
# Local base port for the decryption nodes (macOS AirPlay occupies 5000; use 5005).
DEC_BASE_PORT=5005
# One URL per kfrag; ports must match DEC_BASE_PORT (5005, 5006, 5007, ...).
DECRYPTION_NODE_URLS=http://127.0.0.1:5005,http://127.0.0.1:5006,http://127.0.0.1:5007

# ── Optional ────────────────────────────────────────────────────────────────
# The ops scripts pin the GCP project (CLOUDSDK_CORE_PROJECT=rmbs-495107). To target
# a different deployment, uncomment and set:
# PROJECT=my-gcp-project
